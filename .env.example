# .env.example — NetFoundry Autonomous Edge Router
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#

## CONTAINER ##
# Docker container name. Change if running multiple routers on the same host.
ZITI_CONTAINER_NAME=autonomous-router

## REGISTRATION ##
# Required on first run. Ignored once certs/cert.pem exists.
# Obtain from the NetFoundry console.
REG_KEY=

## TUNNEL MODE ##
# "auto" lets Ziti choose the best tunnel mode.
# "host" or leave blank for host mode (no tunnel listener).
TUNNEL_MODE=auto

## VERBOSITY ##
# Uncomment to pass -v to ziti router run.
#VERBOSE=1

## PROXY ##
# Uncomment to route outbound connections through an HTTP proxy.
#HTTPS_PROXY=http://proxy.corp.example.com:3128

## ADVERTISED ADDRESS ##
# Required when the host's public IP differs from its LAN IP (e.g. behind NAT).
# Format: IP:PORT
#ADVERTISE_ADDRESS=203.0.113.10:443

## AUTO UPDATE ##
# "true" prevents mid-run Ziti binary upgrades.
# Recommended for stable/production deployments.
DISABLE_AUTO_UPDATE=true

## VERSION PIN ##
# Pin a specific Ziti binary version e.g. v1.7.2.
# Bypasses all version checks. Leave blank to track the controller version.
# Set both this AND DISABLE_AUTO_UPDATE=true for a fully static deployment.
#ZITI_VERSION_OVERRIDE=

## DNS SETUP (TUNNEL_MODE=auto only) ##
# All DNS settings below are IGNORED when TUNNEL_MODE is not "auto".
# In host mode Ziti does not run a DNS server — there is nothing to configure.
#
# Set ZITI_DNS_CONFIGURE=false to suppress DNS setup even when TUNNEL_MODE=auto.
# Requires /etc/systemd and /run/systemd volume mounts (see compose.yml).
ZITI_DNS_CONFIGURE=true

# Route ALL DNS through Ziti DNS (recommended):
ZITI_DNS_MODE=all

# [OR] route only specific search domains:
#ZITI_DNS_MODE=domains
#ZITI_DNS_DOMAINS=lan ziti corp internal

# Ziti DNS server IP. Auto-detected from the host's LAN route when unset.
#ZITI_DNS_IP=

# Fallback resolver when Ziti DNS cannot answer a query.
# Auto-detected from the host's current resolver when unset.
#ZITI_DNS_FALLBACK=1.1.1.1

# Disable mDNS interception so .local queries reach Ziti DNS instead of the
# mDNS stack. Required if your DNS server serves .local records.
ZITI_DNS_DISABLE_MDNS=false

# Seconds to wait for Ziti DNS ready before switching systemd-resolved.
# Increase if your controller is slow to bring up the DNS listener.
#ZITI_DNS_WAIT_TIMEOUT=60

# Consecutive failed DNS probes before reverting to host DNS and restarting Ziti.
# Each probe runs ~every 60s. Default of 3 triggers revert after ~3 min.
#ZITI_DNS_HEALTH_THRSH=3

## ZITI CONFIG PATCHES ##
# Written directly into config.yml before Ziti starts.
# These work independently and do NOT require ZITI_DNS_CONFIGURE=true.

# IP range assigned to overlay service addresses (dnsSvcIpRange).
ZITI_DNS_RANGE=100.65.0.0/24

# Upstream resolver Ziti uses for non-overlay lookups (dnsUpstream).
# Auto-detected from the host's current resolver when unset.
# IMPORTANT: when setting explicitly, protocol and port are REQUIRED:
#   udp://IP:PORT  or  tcp://IP:PORT  — e.g. udp://1.1.1.1:53
#ZITI_DNS_UPSTREAM=udp://1.1.1.1:53

## HOSTS ENTRIES ##
# Static /etc/hosts injection before Ziti starts. These records are resolved
# locally by the OS and are never forwarded to the Ziti overlay.
# Separate multiple entries with semicolons.
# See README for all supported entry formats.
HOSTS_ENTRIES=INTERFACE_ASSIGNED

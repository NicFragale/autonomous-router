# .env.example — NetFoundry Autonomous Edge Router
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# .env is listed in .gitignore and will never be committed.

## REGISTRATION ##
# Required on first run. Ignored once certs/cert.pem exists.
# Obtain from the NetFoundry console.
REG_KEY=

## TUNNEL MODE ##
# "auto" lets Ziti choose the best tunnel mode for the host.
# Leave blank to use host mode (default).
TUNNEL_MODE=auto

## AUTO UPDATE ##
# Set to "true" to prevent mid-run Ziti binary upgrades.
# Recommended for stable/production deployments.
DISABLE_AUTO_UPDATE=true

## VERSION PIN ##
# Pin a specific Ziti binary version e.g. v1.7.2
# Leave blank to track the controller version.
ZITI_VERSION_OVERRIDE=

## DNS ##
# IP range assigned to overlay services.
ZITI_DNS_RANGE=100.65.0.0/24

# Upstream resolver used inside Ziti's config.yml.
ZITI_DNS_UPSTREAM=udp://1.1.1.1:53

# Fallback resolver if Ziti DNS cannot answer a query.
ZITI_DNS_FALLBACK=1.1.1.1

## HOSTS ENTRIES ##
# Static /etc/hosts injection before Ziti starts.
# INTERFACE_ASSIGNED = auto-detect host LAN IP + reverse PTR lookup.
# See README for other supported formats.
HOSTS_ENTRIES=INTERFACE_ASSIGNED
